{
  "name": "@sandcastle/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "corepack pnpm exec tsup",
    "dev": "corepack pnpm exec tsx watch src/server.ts",
    "seed": "node dist/seed.js",
    "start": "node dist/server.js",
    "lint": "corepack pnpm exec eslint ../../eslint.config.mjs",
    "test": "corepack pnpm exec vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.2",
    "@prisma/client": "^5.22.0",
    "@sandcastle/db": "workspace:*",
    "@sandcastle/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "nanoid": "^5.0.9",
    "prisma": "^5.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6"
  }
}
