generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PollType {
  single_choice
  multiple_choice
  ranked_choice
}

enum RsvpStatus {
  going
  maybe
  not_going
}

enum NotificationType {
  mention
  thread_reply
  poll
  event
  availability
  reminder
}

enum AttachmentKind {
  image
  gif
  file
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String?
  emailVerifiedAt       DateTime?
  displayName           String
  avatarUrl             String?
  role                  String                 @default("member")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accounts              Account[]
  sessions              Session[]
  profile               UserProfile?
  xboxProfile           XboxProfile?
  invitesCreated        Invite[]               @relation("InviteCreator")
  messages              Message[]
  messageEdits          MessageEdit[]
  reactions             Reaction[]
  threadsParticipating  ThreadParticipant[]
  pollsCreated          Poll[]
  votes                 Vote[]
  eventsOrganized       Event[]                @relation("EventOrganizer")
  rsvps                 Rsvp[]
  availabilityResponses AvailabilityResponse[]
  notifications         Notification[]
  notificationPrefs     NotificationPreference?
  uploadedAttachments   Attachment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invite {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  email      String?
  createdBy  String
  acceptedBy String?
  expiresAt  DateTime?
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  creator    User      @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Restrict)
}

model UserProfile {
  userId           String   @id
  gamertag         String?
  favoriteGames    String[] @default([])
  platforms        String[] @default([])
  typicalPlayTimes String?
  timezone         String   @default("America/New_York")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model XboxProfile {
  userId            String    @id
  xuid              String?
  gamertag          String?
  linkedAt          DateTime?
  lastSyncedAt      DateTime?
  recentGames       Json?
  achievementDigest Json?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Channel {
  id        String    @id @default(cuid())
  name      String    @unique
  topic     String?
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  polls     Poll[]
}

model Message {
  id              String              @id @default(cuid())
  channelId       String
  authorId        String
  body            String
  deletedAt       DateTime?
  editedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  channel         Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author          User                @relation(fields: [authorId], references: [id], onDelete: Restrict)
  thread          Thread?
  edits           MessageEdit[]
  reactions       Reaction[]
  attachments     Attachment[]
  pins            PinnedMessage[]
  mentions        MessageMention[]
  threadReplies   ThreadReply[]
}

model MessageEdit {
  id        String   @id @default(cuid())
  messageId String
  editorId  String
  body      String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  editor    User     @relation(fields: [editorId], references: [id], onDelete: Restrict)
}

model MessageMention {
  messageId String
  userId    String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
}

model Thread {
  id            String              @id @default(cuid())
  rootMessageId String              @unique
  archivedAt    DateTime?
  createdAt     DateTime            @default(now())
  rootMessage   Message             @relation(fields: [rootMessageId], references: [id], onDelete: Cascade)
  replies       ThreadReply[]
  participants  ThreadParticipant[]
}

model ThreadReply {
  id        String   @id @default(cuid())
  threadId  String
  messageId String
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([threadId, messageId])
}

model ThreadParticipant {
  threadId      String
  userId        String
  lastReadAt    DateTime?
  notifications Boolean  @default(true)
  thread        Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Attachment {
  id          String          @id @default(cuid())
  uploaderId  String
  messageId   String?
  eventId     String?
  fileName    String
  contentType String
  byteSize    Int
  kind        AttachmentKind
  storageKey  String          @unique
  createdAt   DateTime        @default(now())
  uploader    User            @relation(fields: [uploaderId], references: [id], onDelete: Restrict)
  message     Message?        @relation(fields: [messageId], references: [id], onDelete: SetNull)
  event       Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model PinnedMessage {
  id        String   @id @default(cuid())
  messageId String
  pinnedBy  String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId])
}

model Poll {
  id          String        @id @default(cuid())
  channelId   String?
  eventId     String?
  creatorId   String
  title       String
  description String?
  type        PollType
  anonymous   Boolean       @default(false)
  deadline    DateTime?
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  channel     Channel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  event       Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  creator     User          @relation(fields: [creatorId], references: [id], onDelete: Restrict)
  options     PollOption[]
  votes       Vote[]
  comments    PollComment[]
}

model PollOption {
  id        String       @id @default(cuid())
  pollId    String
  label     String
  sortOrder Int
  poll      Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     VoteOption[]
}

model Vote {
  id        String       @id @default(cuid())
  pollId    String
  userId    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  poll      Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  options   VoteOption[]

  @@unique([pollId, userId])
}

model VoteOption {
  voteId   String
  optionId String
  rank     Int?
  vote     Vote       @relation(fields: [voteId], references: [id], onDelete: Cascade)
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([voteId, optionId])
}

model PollComment {
  id        String   @id @default(cuid())
  pollId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
}

model Event {
  id             String              @id @default(cuid())
  organizerId    String
  title          String
  description    String?
  finalizedStart DateTime?
  finalizedEnd   DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organizer      User                @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Restrict)
  proposedTimes  EventProposedTime[]
  rsvps          Rsvp[]
  comments       EventComment[]
  attachments    Attachment[]
  polls          Poll[]
}

model EventProposedTime {
  id        String   @id @default(cuid())
  eventId   String
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Rsvp {
  eventId   String
  userId    String
  status    RsvpStatus
  note      String?
  updatedAt DateTime   @updatedAt
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
}

model EventComment {
  id        String   @id @default(cuid())
  eventId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model AvailabilitySchedule {
  id              String                       @id @default(cuid())
  creatorId       String
  title           String
  weekStartsOn    DateTime
  slotMinutes     Int                          @default(60)
  lockedEventId   String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  slots           AvailabilitySlot[]
  responses       AvailabilityResponse[]
  recommendations AvailabilityRecommendation[]
}

model AvailabilitySlot {
  id         String                     @id @default(cuid())
  scheduleId String
  startsAt   DateTime
  endsAt     DateTime
  schedule   AvailabilitySchedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  responses  AvailabilityResponseSlot[]

  @@unique([scheduleId, startsAt, endsAt])
}

model AvailabilityResponse {
  id          String                     @id @default(cuid())
  scheduleId  String
  userId      String
  submittedAt DateTime                   @default(now())
  schedule    AvailabilitySchedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots       AvailabilityResponseSlot[]

  @@unique([scheduleId, userId])
}

model AvailabilityResponseSlot {
  responseId String
  slotId     String
  response   AvailabilityResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  slot       AvailabilitySlot     @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@id([responseId, slotId])
}

model AvailabilityRecommendation {
  id             String               @id @default(cuid())
  scheduleId     String
  startsAt       DateTime
  endsAt         DateTime
  availableCount Int
  totalCount     Int
  availableIds   String[]
  score          Float
  createdAt      DateTime             @default(now())
  schedule       AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  userId        String  @id
  mentions      Boolean @default(true)
  threadReplies Boolean @default(true)
  polls         Boolean @default(true)
  events        Boolean @default(true)
  availability  Boolean @default(true)
  reminders     Boolean @default(true)
  email         Boolean @default(false)
  push          Boolean @default(false)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
